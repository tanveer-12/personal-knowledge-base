# Neon connection string. Same value for dev and prod.
# Find it in your Neon project dashboard under "Connection Details".
# Format: postgresql://user:pass@ep-xxx.region.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=postgresql://user:pass@ep-xxx.region.aws.neon.tech/neondb?sslmode=require

# "development" locally and in Colab. "production" on Render.
APP_ENV=development

# Comma-separated list of allowed frontend origins for CORS.
# Dev: leave empty (defaults to localhost:3000).
# Prod: set to your Vercel URL and any custom domains.
# Example: https://your-app.vercel.app,https://your-custom-domain.com
ALLOWED_ORIGINS=
