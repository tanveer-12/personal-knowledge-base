# Neon serverless PostgreSQL connection string.
# Find it in your Neon project dashboard under "Connection Details".
# Format: postgresql://user:password@host/dbname?sslmode=require
DATABASE_URL=postgresql://neondb_owner:npg_BweEGTiO6JL9@ep-odd-sun-a436dcfl-pooler.us-east-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require

# Runtime environment. Use "development" locally and in Colab; "production" on Render.
APP_ENV=development

# Public URL exposed by ngrok when running the backend in Google Colab.
# Not used in Docker or Render — set this manually in your actual .env at the
# start of each Colab session after running the ngrok cell.
# NGROK_URL=https://xxxx-xx-xx-xxx-xx.ngrok-free.app
